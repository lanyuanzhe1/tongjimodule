# 提取脚本中所有通过 library() 或 require() 加载的包名
pkgs <- unlist(stringr::str_match_all(readLines(script_path), "library\\(([^)]+)\\)|require\\(([^)]+)\\)"))
pkgs <- unique(pkgs[nzchar(pkgs)]) # 去重并移除空字符
# 安装那些尚未安装的包
to_install <- setdiff(pkgs, installed.packages()[, "Package"])
if (length(to_install) > 0) {
    install.packages(to_install)
} else {
    message("所有依赖包已安装。")
}
